# Copy this file to .env. Defaults target NVIDIA DGX Spark / GB10 with 128 GB unified memory.

# Image
# DGX Spark / GB10 Blackwell image. This is intentionally not the generic upstream vLLM image.
VLLM_BASE_IMAGE=scitrera/dgx-spark-vllm:0.17.0-t5
VLLM_IMAGE_NAME=local/vllm-dgx-spark:latest
VLLM_CONTAINER_NAME=vllm

# Model
VLLM_MODEL=Qwen/Qwen3.6-35B-A3B
VLLM_SERVED_MODEL_NAME=qwen/qwen3-35b-a3b
HUGGING_FACE_HUB_TOKEN=

# Server binding
# Keep localhost by default. Use 0.0.0.0 only behind your own auth/proxy layer.
VLLM_HOST=127.0.0.1
VLLM_PORT=8000

# vLLM sizing
# DGX Spark / GB10 starting point for Qwen3.6-35B-A3B:
# 128K context, 65% unified-memory target, and 3 concurrent sequences.
VLLM_MAX_MODEL_LEN=131072
VLLM_GPU_MEMORY_UTILIZATION=0.65
VLLM_MAX_NUM_SEQS=3
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_TENSOR_PARALLEL_SIZE=1

# Model features
VLLM_ATTENTION_BACKEND=flashinfer
VLLM_TRUST_REMOTE_CODE=true
VLLM_ENABLE_PREFIX_CACHING=true
VLLM_ENABLE_CHUNKED_PREFILL=true
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=qwen3_coder
VLLM_REASONING_PARSER=qwen3

# Optional speculative decoding. Disabled by default for stability on this stack.
# When MTP worked in testing it improved throughput, but it also caused vLLM restarts.
VLLM_SPECULATIVE_CONFIG=
VLLM_MAX_CUDAGRAPH_CAPTURE_SIZE=

# Container resource limits. For a 128 GB unified-memory system, 110g/120g
# leaves room for the host while still protecting it from runaway allocations.
VLLM_SHM_SIZE=64gb
VLLM_MEM_LIMIT=110g
VLLM_MEMSWAP_LIMIT=120g
VLLM_PIDS_LIMIT=4096

# NVIDIA / PyTorch / vLLM runtime knobs
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
NVIDIA_TF32_OVERRIDE=1
TORCH_ALLOW_TF32_CUBLAS_OVERRIDE=1
TORCH_CUDA_ARCH_LIST=12.1f
VLLM_FLOAT32_MATMUL_PRECISION=high
VLLM_FLASHINFER_MOE_BACKEND=throughput
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_LOG_STATS_INTERVAL=10

# Metrics flags
VLLM_KV_CACHE_METRICS=true
VLLM_CUDAGRAPH_METRICS=true
VLLM_ENABLE_MFU_METRICS=true

# Optional LiteLLM proxy profile
# Start with: docker compose --profile litellm up -d --build
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-stable
LITELLM_CONTAINER_NAME=litellm-vllm
LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000
# LiteLLM exposes this model name and routes it to the vLLM service.
LITELLM_MODEL_NAME=qwen/qwen3-35b-a3b
LITELLM_VLLM_MODEL=hosted_vllm/qwen/qwen3-35b-a3b
# Change this before exposing LiteLLM beyond localhost.
LITELLM_MASTER_KEY=sk-change-me
